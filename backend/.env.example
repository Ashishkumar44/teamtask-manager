# Environment Variables Example

# Copy this file to .env and fill in your actual values

# ===== SERVER CONFIGURATION =====
PORT=5000
NODE_ENV=development

# ===== DATABASE CONFIGURATION =====
# Option 1: Local MongoDB
MONGODB_URI=mongodb://localhost:27017/team-task-manager

# Option 2: MongoDB Atlas (Cloud)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/team-task-manager?retryWrites=true&w=majority

# ===== JWT CONFIGURATION =====
# Generate a strong secret key for production!
# You can use: https://strongpasswordgenerator.com/ or openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_change_in_production_12345

# ===== CORS CONFIGURATION (if needed) =====
# CORS_ORIGIN=http://localhost:3000

# ===== EMAIL CONFIGURATION (future feature) =====
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# ===== FILE UPLOAD (future feature) =====
# MAX_FILE_SIZE=10485760
# ALLOWED_FILE_TYPES=pdf,doc,docx,xls,xlsx,jpg,png,gif
